{
  "name": "autohupr",
  "version": "0.5.0",
  "description": "Automatically keep your balenaOS host release up-to-date with this block!",
  "main": "build/main.js",
  "private": true,
  "scripts": {
    "clean": "rimraf build build-test",
    "build": "rimraf build && tsc",
    "build:test": "rimraf build-test && tsc -p tsconfig.test.json",
    "lint": "balena-lint -t tsconfig.json src",
    "lint-fix": "balena-lint -t tsconfig.json --fix src",
    "test": "npm run lint && npm run build && npm run build:test && node --test \"build-test/test/**/*.test.js\"",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schubydoo/autohupr.git"
  },
  "author": "Schuby <schubydoo@users.noreply.github.com>",
  "license": "Apache-2.0",
  "engines": {
    "node": "^24.0.0"
  },
  "bugs": {
    "url": "https://github.com/schubydoo/autohupr/issues"
  },
  "homepage": "https://github.com/schubydoo/autohupr#readme",
  "dependencies": {
    "balena-sdk": "^23.2.0",
    "ms": "3.0.0-canary.202508261828"
  },
  "devDependencies": {
    "@balena/lint": "^9.4.3",
    "@types/node": "^24.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.0"
  }
}
